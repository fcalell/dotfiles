{
    "layer": "top",
    "position": "top",
    "height": 45,
    "margin-top": 8,
    "margin-left": 10,
    "margin-right": 10,
    "spacing": 0,

    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["group/spotify", "tray",  "pulseaudio", "custom/power"],

    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate",
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        }
    },

    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%A, %B %d, %Y}",
        "tooltip-format": "<tt><big>{calendar}</big></tt>"
    },

    "tray": {
        "spacing": 10,
        "icon-size": 18
    },

    "custom/power": {
        "format": "⏻",
        "tooltip": false,
        "on-click": "wlogout -b 2"
    },

    "group/spotify": {
        "orientation": "horizontal",
        "modules": ["custom/spotify-prev", "custom/spotify", "custom/spotify-next"]
    },

    "custom/spotify-prev": {
        "format": "󰒮",
        "tooltip": false,
        "interval": 1,
        "exec-if": "playerctl -p spotify status 2>/dev/null",
        "exec": "echo ' '",
        "on-click": "playerctl -p spotify previous"
    },

    "custom/spotify": {
        "format": "󰓇 {}",
        "max-length": 40,
        "interval": 1,
        "exec": "playerctl -p spotify metadata --format '{{ artist }} - {{ title }}' 2>/dev/null",
        "exec-if": "playerctl -p spotify status 2>/dev/null",
        "on-click": "playerctl -p spotify play-pause",
        "on-scroll-up": "playerctl -p spotify next",
        "on-scroll-down": "playerctl -p spotify previous"
    },

    "custom/spotify-next": {
        "format": "󰒭",
        "tooltip": false,
        "interval": 1,
        "exec-if": "playerctl -p spotify status 2>/dev/null",
        "exec": "echo ' '",
        "on-click": "playerctl -p spotify next"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-icons": {
            "default": ["󰕿", "󰖀", "󰕾"]
        },
        "format-muted": "󰝟 {volume}%",
        "on-click": "pavucontrol",
        "scroll-step": 5
    }
}
